# ConsumptionAnalyzer — environment configuration
# Copy this file to .env and fill in values as needed.
# Never commit .env to source control.

# Path to input/output data directory
DATA_DIR=./data

# Logging verbosity: silent | info | debug
LOG_LEVEL=info

# Max pages to process per PDF file (0 = all pages)
PDF_MAX_PAGES=0

# Output CSV field delimiter
CSV_DELIMITER=,

# Anthropic-compatible AI configuration — required for --analyze (STORY-003)
# AI_MODEL: model ID passed to the Anthropic API
#   balanced reasoning (default) → anthropic--claude-sonnet-latest
#   lightweight/fast             → anthropic--claude-haiku-latest
#   complex multi-step reasoning → anthropic--claude-opus-latest
AI_MODEL=anthropic--claude-4.7-opus
AI_MAX_TOKENS=16000
# AI_API_KEY: API key for the AI service — keep secret, never commit
AI_API_KEY=your-api-key-here
# AI_BASE_URL: custom base URL for AI API (leave empty to use Anthropic default)
AI_BASE_URL=
