# ConsumptionAnalyzer — environment configuration
# Copy this file to .env and fill in values as needed.
# Never commit .env to source control.

# Path to input/output data directory
DATA_DIR=./data

# Logging verbosity: silent | info | debug
LOG_LEVEL=info

# Max pages to process per PDF file (0 = all pages)
PDF_MAX_PAGES=0

# Output CSV field delimiter
CSV_DELIMITER=,

# Anthropic-compatible AI configuration — required for --analyze (STORY-003)
# AI_MODEL: model ID for Steps 1–3 of --analyze (sonnet — balanced reasoning)
AI_MODEL=claude-sonnet-4-5
# AI_MODEL_SENIOR: model ID for Steps 4–5 of --analyze (opus — complex multi-step reasoning)
AI_MODEL_SENIOR=claude-opus-4-5
# AI_MAX_TOKENS: max tokens per AI response
AI_MAX_TOKENS=8192
# AI_API_KEY: API key for the AI service — keep secret, never commit
AI_API_KEY=your-api-key-here
# AI_BASE_URL: custom base URL for AI API (leave empty to use Anthropic default)
AI_BASE_URL=
# AI_PIPELINE_CONCURRENCY: max parallel AI calls in Steps 1–3 of --analyze (default: 15)
# Lower this if you hit sustained 429 rate-limit errors; raise it (up to ~30) on high-quota accounts
AI_PIPELINE_CONCURRENCY=15
