# SpecGantry .env.example — Release 3.0.0
# Generated: 2026-06-27
#
# Copy to .env and fill in ALL values before running deploy.sh
# NEVER commit .env to version control

# == Application config ==
# (safe to have in .env — not secret, but environment-specific)

# Path to input/output data directory
DATA_DIR=./data

# Logging verbosity: silent | info | debug
LOG_LEVEL=info

# Max pages to process per PDF file (0 = all pages)
PDF_MAX_PAGES=0

# Output CSV field delimiter (default is comma)
CSV_DELIMITER=,

# == Secrets ==
# (replace every ...replace... before using --analyze)

# API key for the Anthropic-compatible AI service
AI_API_KEY=...replace...

# Model ID — e.g. anthropic--claude-sonnet-latest or anthropic--claude-4.7-opus
AI_MODEL=anthropic--claude-sonnet-latest

# Custom AI API base URL (leave empty for direct Anthropic API)
AI_BASE_URL=...replace...

# Max tokens for AI response — 32000 recommended for v3.0.0 3-level pipeline
AI_MAX_TOKENS=32000
