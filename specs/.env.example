# SpecGantry .env.example — Release 4.6.0
# Generated: 2026-06-30
#
# Copy to .env at the project root and fill in ALL values before running deploy.sh
# NEVER commit .env to version control

# == Application config ==
# (environment-specific settings — not secret, safe in .env)

# Path to input/output data directory (default: ./data)
DATA_DIR=./data

# Logging verbosity: silent | info | debug
LOG_LEVEL=info

# Max pages to process per PDF file (0 = all pages)
PDF_MAX_PAGES=0

# Output CSV field delimiter
CSV_DELIMITER=,

# Max tokens per AI response
AI_MAX_TOKENS=8192

# Custom AI API base URL — leave empty to use Anthropic default
AI_BASE_URL=

# Max simultaneous AI API calls during --analyze Steps 1-3 (default 15)
AI_PIPELINE_CONCURRENCY=15

# == Secrets ==
# (replace every ...replace... before running --analyze or --transform)

# Anthropic API key — required for --analyze and --transform (STORY-006 industry inference)
AI_API_KEY=...replace...

# == AI model config ==
# (not secrets but should match your Anthropic account's available models)

# Model ID for Steps 1-3 of --analyze (sonnet) and --transform industry inference
AI_MODEL=claude-sonnet-4-5

# Model ID for Steps 4-5 of --analyze (opus)
AI_MODEL_SENIOR=claude-opus-4-5
